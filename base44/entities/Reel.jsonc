{
  "name": "Reel",
  "type": "object",
  "properties": {
    "listing_url": {
      "type": "string",
      "title": "Listing URL"
    },
    "script": {
      "type": "string",
      "title": "Script"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "generating",
        "complete",
        "rendering",
        "ready",
        "failed"
      ],
      "default": "generating"
    },
    "video_url": {
      "type": "string",
      "title": "Video URL"
    },
    "property_address": {
      "type": "string",
      "title": "Property Address"
    },
    "did_video_id": {
      "type": "string",
      "title": "D-ID Talk ID"
    },
    "background_url": {
      "type": "string",
      "title": "Background URL"
    }
  },
  "required": [
    "listing_url"
  ]
}